# ========================== 基础设置 ==========================
CONFIG_TARGET_ramips=y                             # 目标平台：RAMIPS 架构
CONFIG_TARGET_ramips_mt7621=y                      # 芯片方案：MT7621
CONFIG_TARGET_ramips_mt7621_DEVICE_iptime_a3004ns-dual=y  # 设备型号：ipTIME A3004NS-dual
CONFIG_TARGET_ROOTFS_PARTSIZE=32128                # 根分区大小 32128KB（你指定，保留不变）

# ====================== USB 核心支持（必须） ======================
CONFIG_USB_SUPPORT=y                               # 启用 USB 子系统
CONFIG_PACKAGE_kmod-usb-xhci-mtk=y                 # MTK 平台 USB3 主控驱动（A3004NS 专用）
CONFIG_PACKAGE_kmod-usb-core=y                     # USB 核心基础驱动
CONFIG_PACKAGE_kmod-usb2=y                         # USB 2.0 驱动
CONFIG_PACKAGE_kmod-usb3=y                         # USB 3.0 驱动
CONFIG_PACKAGE_kmod-usb-storage=y                  # USB 存储设备支持（U盘/硬盘）
CONFIG_PACKAGE_kmod-usb-storage-uas=y              # USB 高速 UAS 协议（提升传输速度）
CONFIG_PACKAGE_block-mount=y                       # 块设备自动挂载工具

# ====================== ksmbd服务（替代samba4） ======================
CONFIG_PACKAGE_kmod-fs-ksmbd=y                     # 内核态 SMB 服务模块
CONFIG_PACKAGE_ksmbd-server=y                      # 用户态 SMB 服务
CONFIG_PACKAGE_ksmbd-utils=y                       # ksmbd 管理工具
CONFIG_PACKAGE_luci-app-ksmbd=y                    # 网页端 ksmbd 设置界面
CONFIG_PACKAGE_luci-i18n-ksmbd-zh-cn=y             # ksmbd 中文语言包

# ============= 文件系统支持（EXT4 + NTFS读写 + exFAT + UTF-8） =============
CONFIG_PACKAGE_kmod-fs-ext4=y                      # EXT4 文件系统支持（Linux 原生格式）
CONFIG_PACKAGE_kmod-fuse=y                         # FUSE 虚拟文件系统（ntfs-3g 依赖）
CONFIG_PACKAGE_ntfs-3g=y                           # NTFS 分区完整读写支持
CONFIG_PACKAGE_kmod-nls-utf8=y                     # UTF-8 编码（解决中文文件名乱码）
CONFIG_PACKAGE_kmod-lib-crc16=y                    # CRC16 校验库（系统底层通用依赖）

# ======================= 系统基础 + 网页管理 =======================
CONFIG_PACKAGE_kmod-reboot=y                       # 内核重启支持（修复重启异常）

# ======================== 防火墙内核模块 ========================
CONFIG_PACKAGE_xtables-nft=y                       # nftables 命令行工具（新版防火墙）

# ======================== 全锥 NAT（游戏/联机必备） ========================
CONFIG_PACKAGE_luci-app-fullconenat=y              # 全锥 NAT 网页设置（游戏联机/Open NAT）
