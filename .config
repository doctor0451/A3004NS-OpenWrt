# ========================== 基础设置 ==========================
CONFIG_TARGET_ramips=y                             # 目标平台：RAMIPS 架构
CONFIG_TARGET_ramips_mt7621=y                      # 芯片方案：MT7621
CONFIG_TARGET_ramips_mt7621_DEVICE_iptime_a3004ns-dual=y  # 设备型号：ipTIME A3004NS-dual
CONFIG_TARGET_ROOTFS_PARTSIZE=32512                 # 根分区 32512 KB（适配32M闪存）
CONFIG_TARGET_ROOTFS_SQUASHFS=y                     # 启用SquashFS固件（生成sysupgrade通刷固件）
CONFIG_TARGET_ROOTFS_JFFS2=y                       # 启用可读写JFFS2分区（保存配置与安装软件）

# ====================== USB 核心支持 ======================
CONFIG_USB_SUPPORT=y                               # USB总开关：启用整个USB子系统
#CONFIG_PACKAGE_kmod-usb-xhci-hcd=y                 # XHCI主控制器驱动（USB3.0标准通用版）
CONFIG_PACKAGE_kmod-usb-xhci-mtk=y                 # MTK平台USB3.0专用驱动（A3004NS必备）
CONFIG_PACKAGE_kmod-usb-core=y                     # USB核心基础驱动（所有USB设备依赖）
CONFIG_PACKAGE_kmod-usb2=y                         # USB 2.0驱动支持
CONFIG_PACKAGE_kmod-usb3=y                         # USB 3.0驱动支持
CONFIG_PACKAGE_kmod-usb-storage=y                  # USB存储设备驱动（U盘/移动硬盘）
CONFIG_PACKAGE_kmod-usb-storage-uas=y              # USB高速UAS协议（提升大文件传输速度）
CONFIG_PACKAGE_block-mount=y                       # 块设备自动挂载工具（系统自动识别U盘）

# ====================== 文件共享（ksmbd） ======================
CONFIG_PACKAGE_kmod-fs-ksmbd=y                     # 内核态SMB文件系统模块
CONFIG_PACKAGE_ksmbd-server=y                      # 用户态SMB服务端程序
CONFIG_PACKAGE_ksmbd-utils=y                       # SMB用户/目录管理工具
CONFIG_PACKAGE_luci-app-ksmbd=y                    # SMB网页配置界面
CONFIG_PACKAGE_luci-i18n-ksmbd-zh-cn=y             # SMB中文语言包

# ============= 文件系统支持 =================
CONFIG_PACKAGE_kmod-fs-ext4=y                      # Linux原生EXT4文件系统支持
CONFIG_PACKAGE_kmod-fuse=y                         # FUSE用户态文件系统（ntfs-3g必需依赖）
CONFIG_PACKAGE_ntfs-3g=y                           # NTFS分区完整读写支持
CONFIG_PACKAGE_kmod-nls-utf8=y                     # UTF8编码支持（解决中文文件名乱码）
CONFIG_PACKAGE_kmod-lib-crc16=y                    # CRC16校验库（USB/文件系统底层依赖）

# ======================= 系统基础 =======================
CONFIG_PACKAGE_kmod-reboot=y                       # 内核重启修复（解决部分机型重启失效）

# ======================== 防火墙（无重复纯净版） ========================
CONFIG_PACKAGE_kmod-ipt-core=y                     # iptables核心内核模块
CONFIG_PACKAGE_kmod-ipt-conntrack=y                # 连接跟踪模块（状态防火墙/NAT必需）
CONFIG_PACKAGE_kmod-ipt-nat=y                      # NAT转发模块（路由器上网/端口映射）
CONFIG_PACKAGE_kmod-nft-compat=y                   # nftables兼容层（兼容旧iptables规则）
CONFIG_PACKAGE_iptables-nft=y                      # iptables nftables后端
CONFIG_PACKAGE_xtables-legacy=y                    # 传统iptables命令兼容
CONFIG_PACKAGE_xtables-nft=y                       # nftables新一代防火墙命令工具

# ======================== 全锥 NAT（纯净无重复） ========================
CONFIG_PACKAGE_kmod-ipt-fullconenat=y              # 全锥NAT内核底层模块
CONFIG_PACKAGE_iptables-mod-fullconenat=y          # iptables全锥NAT控制工具
CONFIG_PACKAGE_luci-app-fullconenat=y              # 全锥NAT网页配置界面
