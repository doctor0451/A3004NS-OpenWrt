# This is an empty file, please overwrite it after generating the .config file with the source code


#以下是我的代码
# 启用 32MB 闪存支持（如果未自动检测）
CONFIG_MTD_SPI_NOR_USE_4K_SECTORS=y
CONFIG_MTD_SPI_NOR_SECTIONS=y

# 确保固件分区解析正确（兼容 denx,uimage）
CONFIG_MTD_SPLIT_FIRMWARE=y
CONFIG_MTD_SPLIT_FIRMWARE_NAME="denx,uimage"

# 可选：增加 rootfs 分区大小（配合扩大后的 firmware）
CONFIG_TARGET_ROOTFS_PARTSIZE=300  # 单位 MB，根据你固件内容调整，一般 300MB 足够

# 确保启用 PCIe 及 WiFi 驱动（你的 DTS 中已启用，但确保 .config 包含）
CONFIG_PCIE_MT7621=y
CONFIG_MT76_CORE=y
CONFIG_MT76x2E=y  # MT7612E 或 MT7603E，根据实际硬件
