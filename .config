#以下是我的代码
# 在现有.config基础上添加以下配置
# 32M闪存支持
CONFIG_MTD_SPI_NOR_USE_4K_SECTORS=y
CONFIG_MTD_SPI_NOR_DEFAULT_4K_SECTORS=y
CONFIG_MTD_UBI_BLOCK=y

# 内核参数
CONFIG_CMDLINE="console=ttyS0,115200 rootfstype=squashfs,jffs2"
CONFIG_CMDLINE_EXTEND=y

# 重启修复
CONFIG_MAGIC_SYSRQ=y
CONFIG_EMBEDDED=y
CONFIG_EXPERT=y

# 内存和缓存优化
CONFIG_SLUB=y
CONFIG_SLUB_DEBUG_ON=n
CONFIG_SLUB_MEMCG_SYSFS_ON=n
