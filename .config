# ========================== 基础设置 ==========================
CONFIG_TARGET_ramips=y                             # 目标平台：RAMIPS 架构
CONFIG_TARGET_ramips_mt7621=y                      # 芯片方案：MT7621
CONFIG_TARGET_ramips_mt7621_DEVICE_iptime_a3004ns-dual=y  # 设备型号：ipTIME A3004NS-dual
CONFIG_TARGET_ROOTFS_PARTSIZE=32512                 # 根分区 32512 KB（你指定，保留不变）

# ====================== USB 核心支持 ======================
CONFIG_USB_SUPPORT=y                               # USB 总开关
CONFIG_PACKAGE_kmod-usb-xhci-mtk=y                 # MTK USB3 主控驱动
CONFIG_PACKAGE_kmod-usb-core=y                     # USB 核心基础驱动
CONFIG_PACKAGE_kmod-usb2=y                         # USB 2.0 支持
CONFIG_PACKAGE_kmod-usb3=y                         # USB 3.0 支持
CONFIG_PACKAGE_kmod-usb-storage=y                  # U盘/移动硬盘支持
CONFIG_PACKAGE_kmod-usb-storage-uas=y              # USB 高速 UAS 协议
CONFIG_PACKAGE_block-mount=y                       # 块设备自动挂载工具

# ====================== 文件共享（ksmbd） ======================
CONFIG_PACKAGE_kmod-fs-ksmbd=y                     # 内核态 SMB 模块
CONFIG_PACKAGE_ksmbd-server=y                      # SMB 服务
CONFIG_PACKAGE_ksmbd-utils=y                       # SMB 管理工具
CONFIG_PACKAGE_luci-app-ksmbd=y                    # SMB 网页配置
CONFIG_PACKAGE_luci-i18n-ksmbd-zh-cn=y             # SMB 中文语言包

# ============= 文件系统支持 =================
CONFIG_PACKAGE_kmod-fs-ext4=y                      # EXT4 格式支持
CONFIG_PACKAGE_kmod-fuse=y                         # FUSE 虚拟文件系统
CONFIG_PACKAGE_ntfs-3g=y                           # NTFS 完整读写
CONFIG_PACKAGE_kmod-nls-utf8=y                     # UTF-8 中文编码
CONFIG_PACKAGE_kmod-lib-crc16=y                    # CRC16 底层依赖库

# ======================= 系统基础 =======================
CONFIG_PACKAGE_kmod-reboot=y                       # 内核重启修复

# ======================== 防火墙（无重复纯净版） ========================
CONFIG_PACKAGE_kmod-ipt-core=y                     # iptables 核心模块
CONFIG_PACKAGE_kmod-ipt-conntrack=y                # 连接跟踪
CONFIG_PACKAGE_kmod-ipt-nat=y                      # NAT 转发（上网必备）
CONFIG_PACKAGE_kmod-nft-compat=y                   # iptables/nftables 兼容层
CONFIG_PACKAGE_iptables-nft=y                      # iptables 新后端
CONFIG_PACKAGE_xtables-legacy=y                    # 传统 iptables 命令兼容
CONFIG_PACKAGE_xtables-nft=y                       # nftables 新一代命令工具

# ======================== 全锥 NAT（纯净无重复） ========================
CONFIG_PACKAGE_kmod-ipt-fullconenat=y              # 全锥 NAT 内核模块
CONFIG_PACKAGE_iptables-mod-fullconenat=y          # 全锥 NAT 工具
CONFIG_PACKAGE_luci-app-fullconenat=y              # 全锥 NAT 网页设置
